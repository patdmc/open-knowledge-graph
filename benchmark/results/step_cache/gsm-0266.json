    "description": "Calculate transfer fees (3% of selling price)",
    "operation": "multiply",
    "operands": [
      400000,
      0.03
    ],
    "result": 12000,
    "variable": "transfer_fees"
  },
  {
    "step": 2,
    "description": "Calculate brokerage fee (5% of selling price)",
    "operation": "multiply",
    "operands": [
      400000,
      0.05
    ],
    "result": 20000,
    "variable": "brokerage_fee"
  },
  {
    "step": 3,
    "description": "Total fees paid (transfer + brokerage)",
    "operation": "add",
