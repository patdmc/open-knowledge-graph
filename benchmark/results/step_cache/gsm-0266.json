      12000,
      20000
    ],
    "result": 32000,
    "variable": "total_fees"
  },
  {
    "step": 4,
    "description": "Total deductions (fees + loan repayment)",
    "operation": "add",
    "operands": [
      32000,
      250000
    ],
    "result": 282000,
    "variable": "total_deductions"
  },
  {
    "step": 5,
    "description": "Net proceeds (selling price minus total deductions)",
    "operation": "subtract",
    "operands": [
      400000,
      282000
    ],
    "result": 118000,
    "variable": "net_proceeds"
  }
